{
  "name": "kilo-blog",
  "private": true,
  "version": "0.1.0",
  "description": "Editorial blog and CMS — Spring Boot backend + React frontend",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta --kill-others-on-fail \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && mvn package -DskipTests"
  },
  "devDependencies": {
    "concurrently": "9.1.0"
  }
}
